{
  "name": "Passos Mágicos – Datathon Dev",

  // Imagem base direta — sem Dockerfile customizado
  // TensorFlow instala HDF5 embutido via pip (não precisa de libhdf5-dev)
  "image": "mcr.microsoft.com/devcontainers/python:3.10-bullseye",

  // ── Extensões VS Code instaladas automaticamente ─────────────────────────
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python", 
        "ms-python.pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "charliermarsh.ruff",
        "ms-python.black-formatter",
        "mechatroner.rainbow-csv",
        "eamodio.gitlens",
        "ms-python.isort",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian"
      ],
      "settings": {
        // Configurações básicas do interpretador (não causam aviso de schema)
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "jupyter.notebookFileRoot": "${workspaceFolder}/notebooks",
        "jupyter.askForKernelRestart": false,
        "terminal.integrated.defaultProfile.linux": "bash"
        // Demais settings (formatadores, linters) estão em .vscode/settings.json
      }
    }
  },

  // ── Portas encaminhadas ───────────────────────────────────────────────────
  "forwardPorts": [8501, 8888],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openBrowser"
    },
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "notify"
    }
  },

  // ── Comando executado após a criação do container ─────────────────────────
  // Instala todas as dependências (app + dev)
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt -r requirements-dev.txt",

  // ── Usuário remoto (não root) ─────────────────────────────────────────────
  "remoteUser": "vscode",

  // ── Variáveis de ambiente ─────────────────────────────────────────────────
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}",
    // Desabilita telemetria do TensorFlow
    "TF_CPP_MIN_LOG_LEVEL": "2"
  }
}

